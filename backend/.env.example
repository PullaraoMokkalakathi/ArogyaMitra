# ══════════════════════════════════════════════════════════════
# ArogyaMitra Backend — Environment Variables
# ══════════════════════════════════════════════════════════════
# HOW TO USE:
#   1. Copy this file: cp .env.example .env
#   2. Fill in actual values in .env
#   3. NEVER commit .env to GitHub
#   4. Keep .env inside .gitignore
# ══════════════════════════════════════════════════════════════


# ── Application ────────────────────────────────────────────────
APP_NAME=ArogyaMitra
ENVIRONMENT=development
# Options: development | staging | production
DEBUG=true


# ── Database ───────────────────────────────────────────────────
# Development (SQLite)
DATABASE_URL=sqlite:///./arogya_mitra.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name


# ── JWT / Security ─────────────────────────────────────────────
# Generate a strong key:
# python -c "import secrets; print(secrets.token_hex(32))"

JWT_SECRET_KEY=your_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7


# ── AI — Gemini ────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here


# ── AI — Groq ──────────────────────────────────────────────────
# Get key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here


# ── CORS ───────────────────────────────────────────────────────
# No trailing slash, comma separated
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_GENERAL=100/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_AI=10/minute